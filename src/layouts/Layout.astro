---
export interface Props {
  title?: string;
}
const { title = 'Creator Pulse' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Creator Pulse — Panel de analíticas premium para creadores de contenido multiplataforma." />
    <meta name="theme-color" content="#F1F4F5" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='22' fill='%23FFFFFF'/><circle cx='50' cy='50' r='22' fill='none' stroke='%23098058' stroke-width='8'/><circle cx='50' cy='50' r='8' fill='%23098058'/></svg>"
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
