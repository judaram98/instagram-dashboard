# Variables de entorno requeridas para el despliegue en Netlify
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio.

# ── API Keys (se configuran en Netlify → Site Settings → Environment Variables) ──
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# ── Supabase (valores públicos seguros para exponer en el cliente) ──
PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
